{
  "name": "GenAI & AI Agents — Lab Environment",
  "image": "mcr.microsoft.com/devcontainers/universal:2",

  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.11"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "18",
      "pnpmVersion": "9"
    }
  },

  "postCreateCommand": "bash .devcontainer/setup.sh",

  "forwardPorts": [5173],

  "portsAttributes": {
    "5173": {
      "label": "Lab 1 — Web App Preview",
      "onAutoForward": "notify"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "github.copilot",
        "github.copilot-chat",
        "ms-python.python",
        "ms-toolsai.jupyter"
      ],
      "settings": {
        "github.copilot.enable": {
          "*": true
        }
      }
    }
  }
}
